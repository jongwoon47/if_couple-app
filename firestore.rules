rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users ──
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        (request.auth.uid == userId || canUpdatePartnerUserForCoupleFlow(userId));
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── inviteCodes ──
    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── couples ──
    match /couples/{coupleId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && isMemberOfCouple(coupleId);

      match /messages/{messageId} {
        allow read, write: if request.auth != null && isMemberOfCouple(coupleId);
      }

      match /events/{eventId} {
        allow read, write: if request.auth != null && isMemberOfCouple(coupleId);
      }

      match /trips/{tripId} {
        allow read, write: if request.auth != null && isMemberOfCouple(coupleId);

        match /plans/{planId} {
          allow read, write: if request.auth != null && isMemberOfCouple(coupleId);
        }
      }

      match /albums/{albumId} {
        allow read, write: if request.auth != null && isMemberOfCouple(coupleId);

        match /photos/{photoId} {
          allow read, write: if request.auth != null && isMemberOfCouple(coupleId);
        }
      }
    }

    // ── translation_limits (Cloud Functions에서만 쓰기) ──
    match /translation_limits/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    function isMemberOfCouple(coupleId) {
      let couple = get(/databases/$(database)/documents/couples/$(coupleId)).data;
      return request.auth.uid in couple.users;
    }

    function canUpdatePartnerUserForCoupleFlow(userId) {
      // 연결/해제 흐름에서 필요한 최소 필드만 타 유저 문서 업데이트 허용
      let changed = request.resource.data.diff(resource.data).changedKeys();
      let allowed = changed.hasOnly([
        'coupleId',
        'hasSeenConnectionComplete',
        'coupleJoinedAt',
        'partnerNickname',
        'lastCoupleId',
        'coupleDisconnectedAt',
        'startDate',
      ]);
      let hasNewCoupleId =
        request.resource.data.coupleId is string &&
        request.resource.data.coupleId.size() > 0;
      let hasOldCoupleId =
        resource.data.coupleId is string &&
        resource.data.coupleId.size() > 0;

      let newCouple = hasNewCoupleId
        ? getAfter(
          /databases/$(database)/documents/couples/$(request.resource.data.coupleId)
        ).data
        : null;
      let oldCouple = hasOldCoupleId
        ? get(
          /databases/$(database)/documents/couples/$(resource.data.coupleId)
        ).data
        : null;

      let validNewMembership =
        hasNewCoupleId &&
        newCouple != null &&
        request.auth.uid in newCouple.users &&
        userId in newCouple.users;
      let validOldMembership =
        hasOldCoupleId &&
        oldCouple != null &&
        request.auth.uid in oldCouple.users &&
        userId in oldCouple.users;

      return allowed && (validNewMembership || validOldMembership);
    }
  }
}
